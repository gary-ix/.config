{
	"name": "vscode-themes",
	"displayName": "vscode-themes",
	"publisher": "gary-ix",
	"version": "1.1.0",
	"license": "SEE LICENSE IN LICENSE.txt",
	"repository": {
		"type": "git",
		"url": "https://github.com/theprogrammergary/.config.git"
	},
	"engines": {
		"vscode": "^1.45.0"
	},
	"scripts": {
		"build": "vsce package",
		"deploy": "vsce publish"
	},
	"keywords": [
		"theme",
		"gruvbox",
		"vim"
	],
	"categories": [
		"Themes"
	],
	"devDependencies": {
		"@vscode/vsce": "^3.7.0"
	},
	"contributes": {
		"themes": [
			{
				"label": "Light",
				"uiTheme": "vs",
				"path": "./themes/light.json"
			},
            {
				"label": "Dark",
				"uiTheme": "vs-dark",
				"path": "./themes/dark.json"
			},
			{
				"label": "Tradester-Dark",
				"uiTheme": "vs-dark",
				"path": "./themes/tradester-dark.json"
			}
		]
	}
}

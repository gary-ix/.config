{
  "name": "Dark Uniform",
  "$schema": "vscode://schemas/color-theme",
  "type": "dark",
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#7c7d8d",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#9ca6ff",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage",
        "storage.type",
        "keyword.operator.new",
        "keyword.operator.expression"
      ],
      "settings": {
        "foreground": "#8b93ff"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "support.type"
      ],
      "settings": {
        "foreground": "#aeb8ff"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#36fb48",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.name.method",
        "meta.method-call",
        "support.function.builtin"
      ],
      "settings": {
        "foreground": "#81fd82"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted",
        "string.template",
        "markup.inline.raw"
      ],
      "settings": {
        "foreground": "#ffce2e"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other"
      ],
      "settings": {
        "foreground": "#8b93ff"
      }
    },
    {
      "scope": [
        "variable",
        "meta.definition.variable.name",
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#d9daec"
      }
    },
    {
      "scope": [
        "variable.language.this",
        "variable.language.self",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#b0ffae"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "entity.other.attribute-name",
        "support.type.property-name"
      ],
      "settings": {
        "foreground": "#b0ffae"
      }
    },
    {
      "scope": [
        "keyword.operator",
        "punctuation.separator",
        "punctuation.accessor"
      ],
      "settings": {
        "foreground": "#c6c7d8"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.bold"
      ],
      "settings": {
        "foreground": "#aeb8ff",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "string.regexp",
        "constant.character.escape",
        "punctuation.definition.template-expression"
      ],
      "settings": {
        "foreground": "#ffce2e"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#e83633"
      }
    }
  ],
  "colors": {
    "focusBorder": "#6c6bff80",
    "foreground": "#d9daec",
    "errorForeground": "#e83633",
    "descriptionForeground": "#7c7d8d",

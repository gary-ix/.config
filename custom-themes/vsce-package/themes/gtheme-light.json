{
  "name": "gtheme-light",
  "$schema": "vscode://schemas/color-theme",
  "tokenColors": [
    {
      "name": "Object literal keys (all languages)",
      "scope": "meta.objectlight-literal.key",
      "settings": {
        "foreground": "#5f8f8e"
      }
    },
    {
      "name": "Change the PHP tags to purple (subjective suggestion)",
      "scope": [
        "punctuation.section.embedded.begin.php",
        "punctuation.section.embedded.end.php"
      ],
      "settings": {
        "foreground": "#ad6e88"
      }
    },
    {
      "settings": {
        "foreground": "#4a4440"
      }
    },
    {
      "scope": "emphasis",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": "strong",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "header",
      "settings": {
        "foreground": "#4f7f83"
      }
    },
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#7a7068",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "constant",
        "support.constant",
        "variable.arguments"
      ],
      "settings": {
        "foreground": "#ad6e88"
      }
    },
    {
      "scope": "constant.rgb-value",
      "settings": {
        "foreground": "#4a4440"
      }
    },
    {

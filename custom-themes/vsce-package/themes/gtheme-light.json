      }
    },
    {
      "scope": "punctuation.quoted",
      "settings": {
        "foreground": "#4a4440"
      }
    },
    {
      "scope": "punctuation.quasi",
      "settings": {
        "foreground": "#c43b2d"
      }
    },
    {
      "name": "URL",
      "scope": [
        "*url*",
        "*link*",
        "*uri*"
      ],
      "settings": {
        "fontStyle": "underline"
      }
    },
    {
      "name": "Python function",

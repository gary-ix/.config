// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
	"active_pane_modifiers": {
		"border_size": 1.0
	},
	"diagnostics_max_severity": "all",
	"inlay_hints": {
		"show_background": false
	},
	"relative_line_numbers": "disabled",
	"minimum_contrast_for_highlights": 45.0,
	"agent_buffer_font_size": 13.0,
	"redact_private_values": false,
	"confirm_quit": true,
	"use_system_window_tabs": false,
	"preview_tabs": {
		"enable_preview_from_file_finder": true
	},
	"bottom_dock_layout": "right_aligned",
	"auto_indent": true,
	"show_wrap_guides": true,
	"hard_tabs": true,
	"gutter": {
		"min_line_number_digits": 3
	},
	"show_edit_predictions": false,
	"git_panel": {
		"scrollbar": {
			"show": "always"
		},
		"collapse_untracked_diff": false,
		"status_style": "icon",
		"sort_by_path": false,
		"dock": "right"
	},
	"agent": {
		"default_height": 320.0,
		"inline_assistant_model": {
			"provider": "zed.dev",
			"model": "claude-sonnet-4"
		},
		"always_allow_tool_actions": true,
		"default_model": {
			"model": "claude-sonnet-4",
			"provider": "zed.dev"
		},
		"notify_when_agent_waiting": "all_screens",
		"default_profile": "ask",
		"dock": "left",
		"play_sound_when_agent_done": true
	},
	"agent_servers": {
		"OpenCode": {
   "type": "custom",
			"command": "opencode",
			"args": ["acp"]
		}
	},
	"base_keymap": "VSCode",
	"buffer_font_family": "JetBrainsMono Nerd Font",
	"buffer_font_size": 15,
	"buffer_font_weight": 300.0,
	"buffer_line_height": {
		"custom": 1.5
	},
	"cursor_blink": true,
	"edit_predictions": {
		"copilot": {
			"enterprise_uri": null,
			"proxy": null,
			"proxy_no_verify": null
		},
		"disabled_globs": [
			"!**/.envConfig.json",
			"**/.env",
			"**/.env.*",
			"**/credentials.json",
			"**/credentials.*.json",
			"**/secret.json",
			"**/secrets.json",
			"**/*.key",
			"**/*.pem",
			"**/*.pfx",
			"**/*.p12",
			"**/*.crt",
			"**/*.cer",
			"**/id_rsa",
			"**/id_dsa",
			"**/.ssh/id_*"
		],
		"enabled_in_text_threads": false,
		"mode": "subtle"
	},
	"file_types": {
		"cpp": ["*.cpp"],
		"tailwindcss": ["*.css"]
	},
	"formatter": "auto",
	"format_on_save": "on",
	"git": {
		"inline_blame": {
			"enabled": false
		}
	},
	"hover_popover_delay": 500,
	"icon_theme": "Zed (Default)",
	"indent_guides": {
		"active_line_width": 2,
		"background_coloring": "disabled",
		"coloring": "fixed",
		"enabled": true,
		"line_width": 1
	},
	"languages": {
		"JavaScript": {
			"code_actions_on_format": {
				"source.fixAll.eslint": true
			}
		},
		"Svelte": {
			"code_actions_on_format": {
				"source.fixAll.eslint": true
			}
		},
		"TypeScript": {
			"code_actions_on_format": {
				"source.fixAll.eslint": true
			}
		}
	},
	"max_tabs": 4,
	"minimap": {
		"show": "never"
	},
	"notification_panel": {
		"dock": "left"
	},
	"project_panel": {
		"sticky_scroll": true,
		"show_diagnostics": "all",
		"scrollbar": {
			"show": "always"
		},
		"default_width": 240.0,
		"auto_fold_dirs": true,
		"dock": "left",
		"entry_spacing": "standard",
		"indent_size": 16.0,
		"indent_guides": {
			"show": "always"
		}
	},
	"scrollbar": {
		"diagnostics": "all",
		"show": "always",
		"axes": {
			"horizontal": null,
			"vertical": null
		}
	},
	"show_signature_help_after_edits": false,
	"show_whitespaces": "boundary",
	"soft_wrap": "editor_width",
	"diagnostics": {
		"inline": {
			"min_column": 102,
			"padding": 0,
			"enabled": true
		},
		"button": true
	},
	"collaboration_panel": {
		"button": false
	},
	"outline_panel": {
		"dock": "left",
		"indent_size": 16.0,
		"button": false
	},
	"tab_bar": {
		"show": false
	},
	"tab_size": 4,
	"tabs": {
		"show_diagnostics": "off",
		"file_icons": true,
		"git_status": true,
		"close_position": "left",
		"show_close_button": "hidden"
	},
	"terminal": {
		"scrollbar": {
			"show": "never"
		},
		"toolbar": {
			"breadcrumbs": false
		},
		"font_weight": 350.0,
		"blinking": "on",
		"cursor_shape": "bar",
		"dock": "left",
		"font_family": "JetBrainsMono Nerd Font",
		"font_features": null,
		"font_size": 14.5
	},
	"title_bar": {
		"show_branch_icon": true, // Show/hide branch icon beside branch switcher
		"show_branch_name": true, // Show/hide branch name
		"show_project_items": true, // Show/hide project host and name
		"show_onboarding_banner": true, // Show/hide onboarding banners
		"show_user_picture": true, // Show/hide user avatar
		"show_sign_in": true, // Show/hide sign-in button
		"show_menus": true // Show/hide menus
	},
	"theme": "Mint light",
	"toolbar": {
		"agent_review": true,
		"breadcrumbs": true,
		"code_actions": true,
		"quick_actions": true,
		"selections_menu": true
	},
	"ui_font_size": 15.0,
	"ui_font_family": "JetBrainsMono Nerd Font",
	"ui_font_weight": 100.0,
	"preferred_line_length": 80
}

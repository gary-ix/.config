{
	"name": "dotfiles-root",
	"private": true,
	"scripts": {
		"lint": "biome lint .",
		"lint:fix": "biome lint --write .",
		"format": "biome format --write .",
		"format:check": "biome format .",
		"theme": "tsx custom-themes/create/controller.ts",
		"mac:install": "bash scripts/mac-install.sh",
		"mac:uninstall": "bash scripts/mac-uninstall.sh",
		"mbp:normal": "sudo npx tsx scripts/mbp-mode.ts normal",
		"mbp:server": "sudo npx tsx scripts/mbp-mode.ts server",
		"mbp:current": "npx tsx scripts/mbp-mode.ts current"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.4",
		"@types/node": "22.18.1",
		"jsonc-parser": "3.3.1",
		"tsx": "4.20.6",
		"typescript": "5.9.2"
	}
}

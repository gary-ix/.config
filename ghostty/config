# https://ghostty.org/docs/config/reference

# Super = ctrl+alt+shift

# Main config
macos-titlebar-style = transparent
macos-icon = chalkboard
window-save-state = always
window-padding-x = 8
window-padding-y = 0
theme = gtheme-dark
background-opacity = 0.95
background-blur = 0
adjust-cell-height = 10%
cursor-style = bar
font-family = JetBrainsMono Nerd Font
font-size = 15 
focus-follows-mouse = true
copy-on-select = true
unfocused-split-opacity = 1

# Command palette
keybind = super+shift+p=unbind
keybind = cmd+ctrl+alt+shift+p=toggle_command_palette

# CMD - open .config
command-palette-entry = title:"Open .config in Cursor",description:"Open ~/.config in a new Cursor window.",action:"text:open -n -a \"Cursor\" --args \"$HOME/.config\"\n"

# CMD - open .zshrc
command-palette-entry = title:"Open .zshrc in Cursor",description:"Open ~/.zshrc in a new Cursor window.",action:"text:open -n -a \"Cursor\" --args \"$HOME/.zshrc\"\n"

# Tab navigation
keybind = ctrl+tab=unbind
keybind = ctrl+shift+tab=unbind
keybind = super+shift+bracket_left=unbind
keybind = super+shift+bracket_right=unbind
keybind = ctrl+alt+shift+r=next_tab
keybind = ctrl+alt+shift+e=previous_tab

# Pane navigation
keybind = super+alt+arrow_left=unbind
keybind = super+alt+arrow_down=unbind
keybind = super+alt+arrow_up=unbind
keybind = super+alt+arrow_right=unbind
keybind = cmd+h=goto_split:left
keybind = cmd+j=goto_split:down
keybind = cmd+k=goto_split:up
keybind = cmd+l=goto_split:right

# Pane creation
keybind = super+d=unbind
keybind = super+shift+d=unbind
keybind = cmd+shift+h=new_split:left
keybind = cmd+shift+j=new_split:down
keybind = cmd+shift+k=new_split:up
keybind = cmd+shift+l=new_split:right


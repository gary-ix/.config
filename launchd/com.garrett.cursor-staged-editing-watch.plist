<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>com.garrett.cursor-staged-editing-watch</string>

	<key>ProgramArguments</key>
	<array>
		<string>/bin/bash</string>
		<string>-lc</string>
		<string>$HOME/.config/scripts/mac-only/cursor/cursor-staged-editing.sh patch</string>
	</array>

	<key>WatchPaths</key>
	<array>
		<string>/Applications/Cursor.app/Contents/Resources/app/extensions/git/dist</string>
	</array>

	<key>RunAtLoad</key>
	<false/>
</dict>
</plist>
